{
  "name": "workspace",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src/ games/ server/ --ext .js,.vue",
    "test": "vitest run",
    "test:watch": "vitest",
    "server:build": "esbuild server/index.js --bundle --platform=node --format=esm --packages=external --outfile=server/dist/server.mjs",
    "server:start": "node server/dist/server.mjs",
    "server:dev": "esbuild server/index.js --bundle --platform=node --format=esm --packages=external --outfile=server/dist/server.mjs --watch"
  },
  "dependencies": {
    "vue": "^3.5.13",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitejs/plugin-vue": "^5.2.3",
    "eslint": "^10.4.0",
    "eslint-plugin-vue": "^10.9.1",
    "globals": "^17.6.0",
    "vite": "^6.3.5",
    "vitest": "^4.1.7"
  }
}
