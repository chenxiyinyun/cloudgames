* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

:root {
  --bg-dark: #0a0a0f;
  --bg-card: #12121a;
  --primary: #00ff88;
  --secondary: #ff0066;
  --accent: #00d4ff;
  --white-team: #e8e8e8;
  --black-team: #333333;
  --text: #e0e0e0;
  --glow-primary: 0 0 20px #00ff8866, 0 0 40px #00ff8833;
  --glow-secondary: 0 0 20px #ff006666, 0 0 40px #ff006633;
}

body {
  font-family: 'Noto Sans SC', sans-serif;
  background: var(--bg-dark);
  color: var(--text);
  min-height: 100vh;
  overflow-x: hidden;
  background-image: 
    linear-gradient(rgba(0, 255, 136, 0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(0, 255, 136, 0.03) 1px, transparent 1px);
  background-size: 50px 50px;
}

#app {
  min-height: 100vh;
}

.screen {
  display: none;
  width: 100%;
  min-height: 100vh;
}

.screen.active {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 20px;
}

h1 {
  font-family: 'Orbitron', sans-serif;
  font-size: 3.5rem;
  font-weight: 900;
  background: linear-gradient(135deg, var(--primary), var(--accent));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  text-shadow: var(--glow-primary);
  margin-bottom: 0.5rem;
  text-align: center;
}

.subtitle {
  font-size: 1.2rem;
  color: var(--accent);
  margin-bottom: 2rem;
  opacity: 0.8;
  text-align: center;
}

.card {
  background: var(--bg-card);
  border: 1px solid rgba(0, 255, 136, 0.2);
  border-radius: 16px;
  padding: 2rem;
  box-shadow: var(--glow-primary);
  max-width: 600px;
  width: 100%;
}

.input-group {
  margin-bottom: 1.5rem;
}

label {
  display: block;
  font-size: 0.9rem;
  color: var(--accent);
  margin-bottom: 0.5rem;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

input {
  width: 100%;
  padding: 0.8rem 1rem;
  font-family: 'Noto Sans SC', sans-serif;
  font-size: 1rem;
  background: rgba(0, 0, 0, 0.4);
  border: 2px solid rgba(0, 255, 136, 0.3);
  border-radius: 8px;
  color: var(--text);
  outline: none;
  transition: all 0.3s ease;
}

input:focus {
  border-color: var(--primary);
  box-shadow: var(--glow-primary);
}

.btn {
  font-family: 'Orbitron', sans-serif;
  font-size: 0.9rem;
  font-weight: 700;
  padding: 0.9rem 1.8rem;
  border: none;
  border-radius: 8px;
  cursor: pointer;
  transition: all 0.3s ease;
  text-transform: uppercase;
  letter-spacing: 0.1em;
}

.btn:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

.btn-primary {
  background: linear-gradient(135deg, var(--primary), #00cc6a);
  color: var(--bg-dark);
  box-shadow: var(--glow-primary);
}

.btn-primary:hover:not(:disabled) {
  transform: translateY(-2px);
  box-shadow: 0 0 30px #00ff8888;
}

.btn-secondary {
  background: linear-gradient(135deg, var(--accent), #0099cc);
  color: var(--bg-dark);
  box-shadow: 0 0 20px #00d4ff66;
}

.btn-danger {
  background: linear-gradient(135deg, var(--secondary), #cc0055);
  color: white;
  box-shadow: var(--glow-secondary);
}

.btn-group {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
  justify-content: center;
}

.divider {
  display: flex;
  align-items: center;
  margin: 1.5rem 0;
  color: rgba(255, 255, 255, 0.3);
}

.divider::before, .divider::after {
  content: '';
  flex: 1;
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(0, 255, 136, 0.3), transparent);
}

.divider span {
  padding: 0 1rem;
  font-size: 0.85rem;
}

.room-code {
  font-family: 'Orbitron', sans-serif;
  font-size: 2.5rem;
  font-weight: 900;
  color: var(--primary);
  text-align: center;
  letter-spacing: 0.3em;
  padding: 1rem;
  background: rgba(0, 255, 136, 0.1);
  border: 2px solid var(--primary);
  border-radius: 12px;
  text-shadow: var(--glow-primary);
  margin-bottom: 1rem;
}

.players-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1rem;
  margin: 1.5rem 0;
}

.team-card {
  background: rgba(0, 0, 0, 0.3);
  border-radius: 12px;
  padding: 1.5rem;
  border: 2px solid;
}

.team-card.white {
  border-color: var(--white-team);
}

.team-card.black {
  border-color: #666;
}

.team-title {
  font-family: 'Orbitron', sans-serif;
  font-size: 1.2rem;
  font-weight: 700;
  margin-bottom: 1rem;
  text-align: center;
}

.team-card.white .team-title {
  color: var(--white-team);
}

.team-card.black .team-title {
  color: #999;
}

.player-item {
  display: flex;
  align-items: center;
  padding: 0.5rem 0;
  border-bottom: 1px solid rgba(255, 255, 255, 0.1);
}

.player-item:last-child {
  border-bottom: none;
}

.player-item.you {
  background: rgba(0, 212, 255, 0.1);
  padding: 0.5rem;
  border-radius: 6px;
}

.player-name {
  flex: 1;
}

.role-tag {
  font-size: 0.75rem;
  padding: 0.2rem 0.6rem;
  border-radius: 20px;
  background: var(--accent);
  color: var(--bg-dark);
}

.waiting-text {
  text-align: center;
  color: rgba(255, 255, 255, 0.5);
  margin-top: 1rem;
  animation: blink 1.5s ease-in-out infinite;
}

@keyframes blink {
  0%, 100% { opacity: 0.5; }
  50% { opacity: 1; }
}

.game-container {
  width: 100%;
  max-width: 1200px;
  margin: 0 auto;
}

.game-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 2rem;
  flex-wrap: wrap;
  gap: 1rem;
}

.team-info {
  display: flex;
  align-items: center;
  gap: 1rem;
  padding: 0.8rem 1.2rem;
  background: rgba(0, 0, 0, 0.4);
  border-radius: 12px;
  border: 2px solid;
}

.team-info.white {
  border-color: var(--white-team);
}

.team-info.black {
  border-color: #666;
}

.team-info .team-name {
  font-family: 'Orbitron', sans-serif;
  font-weight: 700;
}

.team-info.white .team-name {
  color: var(--white-team);
}

.team-info.black .team-name {
  color: #999;
}

.tokens {
  display: flex;
  gap: 0.5rem;
}

.token {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  border: 2px solid;
}

.token.white {
  background: white;
  border-color: white;
  box-shadow: 0 0 10px rgba(255, 255, 255, 0.5);
}

.token.white.earned {
  box-shadow: 0 0 15px rgba(255, 255, 255, 0.8);
}

.token.black {
  background: #222;
  border-color: #444;
}

.token.black.earned {
  background: var(--secondary);
  border-color: var(--secondary);
  box-shadow: 0 0 15px rgba(255, 0, 102, 0.8);
}

.token.empty {
  opacity: 0.3;
}

.round-info {
  text-align: center;
  font-family: 'Orbitron', sans-serif;
}

.round-number {
  font-size: 1.5rem;
  font-weight: 700;
  color: var(--accent);
}

.game-area {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1.5rem;
}

.screen-panel {
  background: linear-gradient(145deg, var(--bg-card), #0f0f15);
  border: 2px solid rgba(0, 255, 136, 0.3);
  border-radius: 16px;
  padding: 1.5rem;
}

.screen-panel.our-team {
  border-color: var(--primary);
  box-shadow: 0 0 20px rgba(0, 255, 136, 0.2);
}

.screen-title {
  font-family: 'Orbitron', sans-serif;
  font-size: 1.1rem;
  font-weight: 700;
  margin-bottom: 1rem;
  color: var(--accent);
  text-align: center;
}

.keywords-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1rem;
}

.keyword-card {
  aspect-ratio: 1;
  background: rgba(0, 0, 0, 0.4);
  border: 2px solid rgba(0, 255, 136, 0.3);
  border-radius: 12px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.keyword-card.visible {
  background: rgba(0, 255, 136, 0.1);
  border-color: var(--primary);
}

.keyword-number {
  font-family: 'Orbitron', sans-serif;
  font-size: 1.5rem;
  font-weight: 900;
  color: var(--primary);
  margin-bottom: 0.5rem;
}

.keyword-word {
  font-size: 1rem;
  font-weight: 700;
  text-align: center;
  word-break: break-word;
  padding: 0 0.5rem;
}

.keyword-word.hidden {
  color: rgba(255, 255, 255, 0.2);
  font-size: 0.9rem;
}

.phase-panel {
  background: rgba(0, 0, 0, 0.3);
  border-radius: 12px;
  padding: 1.5rem;
  border: 1px solid rgba(0, 255, 136, 0.2);
}

.phase-title {
  font-family: 'Orbitron', sans-serif;
  font-size: 1.3rem;
  font-weight: 700;
  color: var(--primary);
  margin-bottom: 1rem;
  text-align: center;
}

.code-display {
  display: flex;
  justify-content: center;
  gap: 1rem;
  margin: 1.5rem 0;
}

.code-digit {
  width: 70px;
  height: 70px;
  background: rgba(0, 0, 0, 0.4);
  border: 2px solid var(--accent);
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: 'Orbitron', sans-serif;
  font-size: 2.5rem;
  font-weight: 900;
  color: var(--accent);
  box-shadow: 0 0 20px rgba(0, 212, 255, 0.3);
}

.code-inputs {
  display: flex;
  justify-content: center;
  gap: 1rem;
  margin: 1.5rem 0;
}

.code-input {
  width: 70px;
  height: 70px;
  text-align: center;
  font-family: 'Orbitron', sans-serif;
  font-size: 2rem;
  font-weight: 700;
  border-radius: 12px;
}

.clue-inputs {
  display: flex;
  flex-direction: column;
  gap: 1rem;
  margin: 1.5rem 0;
}

.clue-input-group {
  display: flex;
  align-items: center;
  gap: 1rem;
}

.clue-index {
  width: 40px;
  height: 40px;
  background: rgba(0, 255, 136, 0.2);
  border: 2px solid var(--primary);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: 'Orbitron', sans-serif;
  font-weight: 700;
  color: var(--primary);
  flex-shrink: 0;
}

.clue-input-field {
  flex: 1;
}

.clue-display {
  display: flex;
  flex-direction: column;
  gap: 1rem;
  margin: 1.5rem 0;
}

.clue-item {
  display: flex;
  align-items: center;
  gap: 1rem;
  padding: 1rem;
  background: rgba(0, 0, 0, 0.3);
  border-radius: 8px;
  border-left: 4px solid var(--primary);
}

.clue-text {
  font-size: 1.2rem;
  font-weight: 700;
}

.note-sheet {
  background: rgba(0, 0, 0, 0.3);
  border-radius: 12px;
  padding: 1.5rem;
  max-height: 400px;
  overflow-y: auto;
}

.note-section {
  margin-bottom: 1.5rem;
}

.note-section:last-child {
  margin-bottom: 0;
}

.note-title {
  font-family: 'Orbitron', sans-serif;
  font-size: 0.9rem;
  color: var(--accent);
  margin-bottom: 0.5rem;
}

.note-round {
  padding: 0.5rem;
  background: rgba(0, 0, 0, 0.2);
  border-radius: 6px;
  margin-bottom: 0.5rem;
  font-size: 0.85rem;
}

.result-panel {
  text-align: center;
  padding: 2rem;
}

.result-title {
  font-family: 'Orbitron', sans-serif;
  font-size: 2.5rem;
  font-weight: 900;
  margin-bottom: 1rem;
}

.result-title.win {
  color: var(--primary);
  text-shadow: var(--glow-primary);
}

.result-title.lose {
  color: var(--secondary);
  text-shadow: var(--glow-secondary);
}

.result-subtitle {
  font-size: 1.2rem;
  margin-bottom: 2rem;
  opacity: 0.8;
}

.result-details {
  background: rgba(0, 0, 0, 0.3);
  border-radius: 12px;
  padding: 1.5rem;
  margin-bottom: 1.5rem;
}

.rules-text {
  font-size: 0.85rem;
  color: rgba(255, 255, 255, 0.6);
  line-height: 1.6;
  margin-top: 1rem;
}

@media (max-width: 768px) {
  h1 { font-size: 2rem; }
  .card { padding: 1.2rem; }
  .players-grid { grid-template-columns: 1fr; }
  .keywords-grid { 
    grid-template-columns: repeat(2, 1fr);
    gap: 0.8rem;
  }
  .code-digit, .code-input { width: 55px; height: 55px; font-size: 1.8rem; }
}
